-- SELECTs sugeridos para testes apÃ³s a carga
-- 1) VisÃ£o geral com JOIN e uso de AS
SELECT
    f.id AS id_funcionario,
    f.nome AS funcionario,
    f.cargo AS cargo,
    f.salario AS salario,
    d.nome AS departamento,
    d.sigla AS sigla_departamento
FROM funcionario AS f
INNER JOIN departamento AS d
    ON f.departamento_id = d.id
ORDER BY d.nome, f.nome;

-- 2) FuncionÃ¡rios do departamento de TI
SELECT
    f.nome AS funcionario,
    f.cargo AS cargo,
    f.salario AS salario
FROM funcionario AS f
INNER JOIN departamento AS d
    ON f.departamento_id = d.id
WHERE d.sigla = 'TI'
ORDER BY f.nome;

-- 3) MÃ©dia salarial por departamento
SELECT
    d.nome AS departamento,
    ROUND(AVG(f.salario), 2) AS media_salarial
FROM funcionario AS f
INNER JOIN departamento AS d
    ON f.departamento_id = d.id
GROUP BY d.nome
ORDER BY d.nome;

-- 4) UPDATE com JOIN (aumentar salÃ¡rios do Marketing em 8%)
UPDATE funcionario AS f
SET salario = salario * 1.08
FROM departamento AS d
WHERE f.departamento_id = d.id
  AND d.sigla = 'MKT';

-- 5) SELECT para conferir o UPDATE
SELECT
    f.nome AS funcionario,
    f.salario AS novo_salario,
    d.sigla AS departamento
FROM funcionario AS f
INNER JOIN departamento AS d
    ON f.departamento_id = d.id
WHERE d.sigla = 'MKT'
ORDER BY f.nome;

-- 6) DELETE de teste com JOIN (excluir recepcionista do Atendimento)
DELETE FROM funcionario AS f
USING departamento AS d
WHERE f.departamento_id = d.id
  AND d.sigla = 'ATD'
  AND f.cargo = 'Recepcionista';

-- 7) SELECT final de conferÃªncia
SELECT
    f.id,
    f.nome,
    f.cargo,
    d.nome AS departamento
FROM funcionario AS f
INNER JOIN departamento AS d
    ON f.departamento_id = d.id
ORDER BY f.id;
